# Vedic Intelligence System — Environment Variables
# Copy this file to .env and fill in your credentials

# Supabase (PostgreSQL + pgvector)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Neo4j Aura (Knowledge Graph)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password

# Pinecone (Cloud Vector Index)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=vis-verses
PINECONE_ENVIRONMENT=us-east-1

# Upstash Redis (Caching)
UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your-token

# HuggingFace (Model Hub)
HUGGINGFACE_TOKEN=hf_your-token

# Models
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Application
APP_ENV=development                             # development | production
LOG_LEVEL=INFO
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Data Sources
GRETIL_BASE_URL=https://gretil.sub.uni-goettingen.de/gretil/1_sanskr/
DCS_REPO_URL=https://github.com/ambuda-org/dcs
ARCHIVE_ORG_API_URL=https://archive.org

# arXiv & PubMed
ARXIV_MAX_RESULTS=5
PUBMED_MAX_RESULTS=5
NASA_ADS_API_KEY=your-nasa-ads-key

# Cloudflare R2 (Backup Storage)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=vedic-corpus-backup
