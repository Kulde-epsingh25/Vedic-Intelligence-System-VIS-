# ═══════════════════════════════════════════
#  VIS — Vedic Intelligence System
#  Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# ── Supabase (free 500MB PostgreSQL) ────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# ── Neo4j Aura (free 1GB graph DB) ──────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# ── Pinecone (free 2GB vector cloud) ────────
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX_NAME=vis-verses
PINECONE_ENVIRONMENT=us-east-1

# ── Upstash Redis (free 500K cmds/mo) ───────
UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your-token-here

# ── HuggingFace ─────────────────────────────
HUGGINGFACE_TOKEN=hf_your-token-here

# ── Cloudflare R2 (free 10GB storage) ───────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=vis-corpus

# ── Models ──────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── App ─────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=*

# ── Data Paths ──────────────────────────────
CORPUS_DIR=./corpus
CHROMA_DIR=./data/chroma
MODELS_DIR=./models
